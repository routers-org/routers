{
  "title": "Routers Realtime",
  "uid": "routers-realtime",
  "version": 6,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "tags": ["routers"],
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Throughput (events/s)",
      "description": "One line per stage, aggregated across shards. Every series is a spanmetrics call counter — gaps between lines are work queued (or dropped) between stages.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(routers_calls_total{span_name=\"orchestrate\"}[15s]))",
          "legendFormat": "① orchestrated (raw events)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_calls_total{span_name=\"match_event\"}[15s]))",
          "legendFormat": "② matched",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_calls_total{span_name=\"commit_result\"}[15s]))",
          "legendFormat": "③ results committed",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "Resume vs Restart (events/s)",
      "description": "Whether the matcher could continue the vehicle's prior trellis. A high restart share means the streaming handoff isn't paying off (cold vehicles, diverging history, or lost state).",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 12 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (continuation) (rate(routers_calls_total{span_name=\"match_event\"}[15s]))",
          "legendFormat": "{{continuation}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "Match Outcomes (total)",
      "description": "success = published result. unanchored / disconnected / no_anchor are nominal — the trace itself is unmatchable, not a pipeline fault. internal is ours.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] } } },
      "targets": [
        {
          "expr": "sum by (outcome) (routers_calls_total{span_name=\"match_event\"})",
          "legendFormat": "{{outcome}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Success Rate",
      "description": "Share of match attempts that published a result. Nominal failures count against this but not against health — see the fatal panel for that.",
      "type": "stat",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(routers_calls_total{span_name=\"match_event\",severity=\"ok\"}) / sum(routers_calls_total{span_name=\"match_event\"})",
          "legendFormat": "success",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "Fatal Failures",
      "description": "Errors that are the pipeline's fault (trellis/solver internals). Anything above zero deserves a look.",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(routers_calls_total{span_name=\"match_event\",severity=\"fatal\"}) or vector(0)",
          "legendFormat": "fatal",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 100,
      "title": "Latency",
      "type": "row",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Stage Latency (avg ms per event)",
      "description": "Where an event's wall-clock goes, one line per span. queue_wait is the time a message sat in NATS between services (send-stamp → delivery); everything else is measured in-process.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (span_name) (rate(routers_duration_milliseconds_sum{span_name=~\"orchestrate|context_fetch|reconcile|publish_context|queue_wait|match_event|push|solve|snapshot|publish_result\"}[15s])) / sum by (span_name) (rate(routers_duration_milliseconds_count[15s]))",
          "legendFormat": "{{span_name}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 7,
      "title": "Queue Wait (ms)",
      "description": "Time messages spend in NATS before pickup, per subject family. Rising percentiles mean a consumer is saturating.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(routers_duration_milliseconds_bucket{span_name=\"queue_wait\"}[15s])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(routers_duration_milliseconds_bucket{span_name=\"queue_wait\"}[15s])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(routers_duration_milliseconds_bucket{span_name=\"queue_wait\"}[15s])))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 8,
      "title": "Match Latency (ms)",
      "description": "The matcher's whole per-event span: reconcile handoff → push → solve → snapshot → publish. Split by resume/restart to see what the trellis handoff buys.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (continuation) (rate(routers_duration_milliseconds_sum{span_name=\"match_event\"}[15s])) / sum by (continuation) (rate(routers_duration_milliseconds_count{span_name=\"match_event\"}[15s]))",
          "legendFormat": "avg ({{continuation}})",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(routers_duration_milliseconds_bucket{span_name=\"match_event\"}[15s])))",
          "legendFormat": "p95 (all)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 101,
      "title": "Backlog & Drops",
      "type": "row",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Stage Backlogs (accumulated events)",
      "description": "Counter gaps between stages: contexts published but not yet matched, and results published but not yet committed. Healthy load keeps both near zero; a growing line is a saturated consumer.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 12 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(routers_calls_total{span_name=\"orchestrate\"}) - sum(routers_calls_total{span_name=\"match_event\"})",
          "legendFormat": "contexts awaiting matcher",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(routers_calls_total{span_name=\"publish_result\"}) - sum(routers_calls_total{span_name=\"commit_result\"})",
          "legendFormat": "results awaiting commit",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 10,
      "title": "Drops & Cuts (per second)",
      "description": "point_drop: individual GPS points the matcher rejected (unanchored = off-network, nominal). history_cut: a gap/teleport discarded committed history. bus_drop: undecodable NATS messages.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 12 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (span_name, reason) (rate(routers_calls_total{span_name=~\"point_drop|history_cut|bus_drop\"}[15s]))",
          "legendFormat": "{{span_name}} ({{reason}})",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 11,
      "title": "NATS Server Throughput (msgs/s)",
      "description": "Ground truth from the NATS exporter, independent of application spans.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 39, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(nats_varz_in_msgs[15s]))",
          "legendFormat": "in",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(nats_varz_out_msgs[15s]))",
          "legendFormat": "out",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 12,
      "title": "Collector Health (spans/s)",
      "description": "The telemetry pipeline's own pulse: spans accepted vs refused by the otel-collector. If the routers series go quiet, look here first.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 39, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(otelcol_receiver_accepted_spans_total[15s]))",
          "legendFormat": "accepted",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(otelcol_receiver_refused_spans_total[15s])) or vector(0)",
          "legendFormat": "refused",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 36
}

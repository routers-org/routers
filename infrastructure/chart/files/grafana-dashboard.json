{
  "title": "Routers Realtime",
  "uid": "routers-realtime",
  "version": 5,
  "refresh": "2s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "tags": ["routers"],
  "panels": [
    {
      "id": 1,
      "title": "Event Throughput (events/s)",
      "description": "Aggregated across all orchestrator replicas.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(routers_events_received_total[3s]))",
          "legendFormat": "ingest consumed",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_events_published_total[3s]))",
          "legendFormat": "published to NATS",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_matches_total_success[3s])) + sum(rate(routers_matches_total_no_candidate[3s])) + sum(rate(routers_matches_total_error[3s]))",
          "legendFormat": "matched",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "Orchestrator Processing Latency (ms)",
      "description": "Time from ingest receipt to NATS ack, aggregated across all replicas.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(routers_total_latency_ms_bucket[3s])) by (le))",
          "legendFormat": "p50",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(routers_total_latency_ms_bucket[3s])) by (le))",
          "legendFormat": "p95",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(routers_total_latency_ms_bucket[3s])) by (le))",
          "legendFormat": "p99",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "Events Received (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(routers_events_received_total)",
          "legendFormat": "",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Events Published to NATS (total)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(routers_events_published_total)",
          "legendFormat": "",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "Dropped Events (received − published)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(routers_events_received_total) - sum(routers_events_published_total)",
          "legendFormat": "",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "title": "Store Errors (total)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(routers_store_errors_total)",
          "legendFormat": "",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 7,
      "title": "Per-Event Latency Breakdown (avg ms)",
      "description": "Where time goes per event in the orchestrator. 'Valkey warm-up' is near-zero on cache hits — it only spikes when a worker first sees a vehicle and reads its history. 'other' = total − warm-up − NATS (serialisation, geohash, history filtering).",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(routers_total_latency_ms_sum[3s])) / sum(rate(routers_total_latency_ms_count[3s]))",
          "legendFormat": "total",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_store_latency_ms_sum[3s])) / sum(rate(routers_store_latency_ms_count[3s]))",
          "legendFormat": "valkey warm-up (cache miss only)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_nats_latency_ms_sum[3s])) / sum(rate(routers_nats_latency_ms_count[3s]))",
          "legendFormat": "NATS publish + ack",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_total_latency_ms_sum[3s])) / sum(rate(routers_total_latency_ms_count[3s])) - sum(rate(routers_store_latency_ms_sum[3s])) / sum(rate(routers_store_latency_ms_count[3s]))",
          "legendFormat": "other (deser + geohash + history filter)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 8,
      "title": "Event Age When Received (ms)",
      "description": "How old GPS events are by the time the orchestrator receives them. High values indicate upstream queue backup.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(routers_event_age_ms_bucket[3s])) by (le))",
          "legendFormat": "p50",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(routers_event_age_ms_bucket[3s])) by (le))",
          "legendFormat": "p95",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 9,
      "title": "Match Outcomes (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 27, "w": 8, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(routers_matches_total_success)",
          "legendFormat": "success",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(routers_matches_total_no_candidate)",
          "legendFormat": "no_candidate",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(routers_matches_total_error)",
          "legendFormat": "error",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 10,
      "title": "Match Success Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 27, "w": 8, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(routers_matches_total_success) / (sum(routers_matches_total_success) + sum(routers_matches_total_no_candidate) + sum(routers_matches_total_error))",
          "legendFormat": "success rate",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 11,
      "title": "HMM Solve Time (ms)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 27, "w": 8, "h": 5 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "sum(rate(routers_solve_latency_ms_sum[30s])) / sum(rate(routers_solve_latency_ms_count[30s]))",
          "legendFormat": "avg solve ms",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 12,
      "title": "Match End-to-End Latency (ms)",
      "description": "Time from GPS event emission to matched result — includes ingest queue wait, orchestrator processing, NATS transit, and HMM solve.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(routers_match_latency_ms_sum[30s])) / sum(rate(routers_match_latency_ms_count[30s]))",
          "legendFormat": "avg",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(routers_match_latency_ms_bucket[30s])) by (le))",
          "legendFormat": "p50",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(routers_match_latency_ms_bucket[30s])) by (le))",
          "legendFormat": "p95",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(routers_match_latency_ms_bucket[30s])) by (le))",
          "legendFormat": "p99",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 100,
      "title": "Pipeline Lag",
      "type": "row",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 13,
      "title": "Pipeline Stage Rates (events/s)",
      "description": "Throughput at each stage aggregated across all replicas. Gaps between lines reveal where the pipeline is falling behind — the wider the gap, the deeper the queue at that stage.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(routers_events_received_total[3s]))",
          "legendFormat": "① Ingest → Orchestrator (consumed)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_events_published_total[3s]))",
          "legendFormat": "② Orchestrator → NATS (published)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_matches_total_success[3s])) + sum(rate(routers_matches_total_no_candidate[3s])) + sum(rate(routers_matches_total_error[3s]))",
          "legendFormat": "③ Matcher output (matched/s)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 14,
      "title": "Stage Backlogs (accumulated events)",
      "description": "Orchestrator in-flight = received − published (events actively being processed). NATS backlog = published − matched (events sitting in JetStream waiting for a matcher). Both should stay near zero under a healthy load.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 49, "w": 24, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 12 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(routers_events_received_total) - sum(routers_events_published_total)",
          "legendFormat": "Orchestrator in-flight (received − published)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(routers_events_published_total) - (sum(routers_matches_total_success) + sum(routers_matches_total_no_candidate) + sum(routers_matches_total_error))",
          "legendFormat": "NATS backlog (published − matched)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 15,
      "title": "Stage Latency Breakdown (avg ms)",
      "description": "Time spent at each stage per event. 'Matcher queue wait' is the gap between NATS delivery and the start of the HMM solve — directly shows matcher saturation. 'Valkey warm-up' is near-zero in steady state (in-memory hot path); it only rises when workers first encounter a vehicle after a restart.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 56, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(routers_total_latency_ms_sum[3s])) / sum(rate(routers_total_latency_ms_count[3s]))",
          "legendFormat": "Orchestrator total (ingest recv → NATS ack)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_store_latency_ms_sum[3s])) / sum(rate(routers_store_latency_ms_count[3s]))",
          "legendFormat": "  └ Valkey warm-up (cache miss)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_nats_latency_ms_sum[3s])) / sum(rate(routers_nats_latency_ms_count[3s]))",
          "legendFormat": "  └ NATS publish + ack",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_match_latency_ms_sum[30s])) / sum(rate(routers_match_latency_ms_count[30s])) - sum(rate(routers_solve_latency_ms_sum[30s])) / sum(rate(routers_solve_latency_ms_count[30s]))",
          "legendFormat": "Matcher queue wait (sitting in NATS before pickup)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_solve_latency_ms_sum[30s])) / sum(rate(routers_solve_latency_ms_count[30s]))",
          "legendFormat": "  └ HMM solve",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(routers_match_latency_ms_sum[30s])) / sum(rate(routers_match_latency_ms_count[30s]))",
          "legendFormat": "Matcher total (NATS delivery → result published)",
          "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "interval": "1s", "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 36
}

ns := "routers-dev"
manifests := "../../deploy/local"

nats_url := "nats://127.0.0.1:4222"
valkey_url := "redis://127.0.0.1:6379"

# bench-stub defaults — override with: just bench_pipeline=512 bench-stub
bench_shards := "r3grm,r3grh,r3grq,r3grw,r3grk,r3grj,r3grs,r3grt"
bench_pipeline := "256"
bench_loops := "3"

# List available recipes
default:
    @just --list

# ── Infrastructure ────────────────────────────────────────────────────────────

# Bring up all K8s services (idempotent)
infra-up:
    kubectl create namespace {{ ns }} --dry-run=client -o yaml | kubectl apply -f -
    @# Helm repos
    helm repo add bitnami             https://charts.bitnami.com/bitnami      2>/dev/null || true
    helm repo add nats                https://nats-io.github.io/k8s/helm/charts 2>/dev/null || true
    helm repo add prometheus-community https://prometheus-community.github.io/helm-charts 2>/dev/null || true
    helm repo update
    @# NATS JetStream
    helm upgrade --install nats nats/nats \
        --namespace {{ ns }} \
        --set config.jetstream.enabled=true \
        --set config.jetstream.memoryStore.enabled=true \
        --set config.jetstream.memoryStore.maxSize=768Mi \
        --set config.jetstream.fileStore.enabled=true \
        --set config.jetstream.fileStore.dir=/data \
        --set config.jetstream.fileStore.maxSize=1Gi
    @# Valkey
    helm upgrade --install valkey bitnami/valkey \
        --namespace {{ ns }} \
        --set auth.enabled=false \
        --set replicaCount=1 \
        --set persistence.enabled=false
    @# Prometheus + Grafana
    helm upgrade --install kube-prometheus-stack prometheus-community/kube-prometheus-stack \
        --namespace {{ ns }} \
        --set prometheus.prometheusSpec.scrapeInterval=10s \
        --set prometheus.prometheusSpec.additionalScrapeConfigsSecret.enabled=true \
        --set prometheus.prometheusSpec.additionalScrapeConfigsSecret.name=routers-additional-scrape \
        --set prometheus.prometheusSpec.additionalScrapeConfigsSecret.key=scrape.yaml \
        --set grafana.adminPassword=admin \
        --set alertmanager.enabled=false \
        --set kubeStateMetrics.enabled=true
    kubectl apply -f {{ manifests }}/prometheus-scrape.yaml
    kubectl apply -f {{ manifests }}/grafana-dashboard.yaml
    @just wait-ready

# Wait for all pods to be ready
wait-ready:
    kubectl wait --namespace {{ ns }} --for=condition=ready pod -l app.kubernetes.io/name=nats   --timeout=120s
    kubectl wait --namespace {{ ns }} --for=condition=ready pod -l app.kubernetes.io/name=valkey --timeout=120s
    @echo "All pods ready."

# Tear down all K8s services
infra-down:
    helm uninstall nats                  --namespace {{ ns }} 2>/dev/null || true
    helm uninstall valkey                --namespace {{ ns }} 2>/dev/null || true
    helm uninstall kube-prometheus-stack --namespace {{ ns }} 2>/dev/null || true
    kubectl delete namespace {{ ns }} 2>/dev/null || true

# Show pod status
status:
    kubectl get pods -n {{ ns }}

# ── Port-forwarding ───────────────────────────────────────────────────────────

# Kill all running port-forwards (use before restarting)
pf-kill:
    @pkill -f "kubectl port-forward" 2>/dev/null && echo "killed" || echo "nothing running"

# Forward observability ports to localhost (blocks; Ctrl-C to stop).
# Add --all to also forward NATS and Valkey for local orchestrator mode.
port-forward all="":
    #!/usr/bin/env bash
    set -uo pipefail

    NS={{ ns }}
    ALL={{ all }}

    cleanup() {
        echo ""
        echo "Stopping port-forwards..."
        kill -- -$$ 2>/dev/null || kill $(jobs -p) 2>/dev/null || true
    }
    trap cleanup EXIT INT TERM

    restart_forever() {
        local name=$1; shift
        while true; do
            kubectl "$@" 2>&1 | grep -v "^Forwarding" || true
            echo "[port-forward] ${name} exited — restarting in 1s" >&2
            sleep 1
        done &
    }

    echo "Port-forwarding namespace ${NS} (self-healing)..."
    echo ""

    restart_forever grafana    port-forward -n "${NS}" svc/kube-prometheus-stack-grafana 3000:80
    restart_forever prometheus port-forward -n "${NS}" svc/prometheus-operated 9090:9090

    echo "  Grafana         http://127.0.0.1:3000      (admin/admin)"
    echo "  Prometheus      http://127.0.0.1:9090"

    if [[ -n "$ALL" ]]; then
        restart_forever nats-client  port-forward -n "${NS}" pod/nats-0         4222:4222
        restart_forever nats-monitor port-forward -n "${NS}" pod/nats-0         8222:8222
        restart_forever valkey       port-forward -n "${NS}" svc/valkey-primary 6379:6379
        echo "  NATS            nats://127.0.0.1:4222"
        echo "  NATS monitor    http://127.0.0.1:8222/jsz"
        echo "  Valkey          redis://127.0.0.1:6379"
    else
        echo ""
        echo "  (NATS/Valkey not forwarded — orchestrator runs in-cluster)"
        echo "  Add 'all=1' to also forward those: just port-forward all=1"
    fi

    echo ""
    echo "Press Ctrl-C to stop."

    wait

# ── Docker / K8s ─────────────────────────────────────────────────────────────

# Build and deploy a service. Usage: just deploy <matcher|orchestrator|historian|all>
# "all" deploys historian → orchestrator → all matcher pods.
# Optional prefix filters by shard name: just deploy matcher r3g
# Optional limit caps the count:         just deploy matcher "" 5
deploy service prefix="" limit="0":
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{ service }}" = "all" ]; then
        just deploy historian
        just deploy orchestrator
        just deploy matcher
        exit 0
    fi
    if [ "{{ service }}" = "matcher" ]; then
        docker build -f ../../Dockerfile.matcher -t routers-matcher:latest ../../
        {{ manifests }}/deploy-matchers.sh "{{ prefix }}" "{{ limit }}"
        kubectl rollout restart deployment -l app=matcher -n {{ ns }}
        exit 0
    fi
    docker build -f ../../Dockerfile.{{ service }} -t routers-{{ service }}:latest ../../
    kubectl apply -f {{ manifests }}/{{ service }}.yaml
    kubectl apply -f {{ manifests }}/prometheus-scrape.yaml
    kubectl rollout restart deployment/{{ service }} -n {{ ns }}
    kubectl rollout status deployment/{{ service }} -n {{ ns }} --timeout=120s

# Scale the in-cluster orchestrator to N replicas (competing consumers on same queue)
scale n="2":
    kubectl scale deployment/orchestrator -n {{ ns }} --replicas={{ n }}
    kubectl rollout status deployment/orchestrator -n {{ ns }} --timeout=60s
    @echo "Scaled to {{ n }} orchestrator replicas"

# Show running orchestrator pods and their metrics
orchestrator-status:
    #!/usr/bin/env bash
    echo "=== Pods ==="
    kubectl get pods -n {{ ns }} -l app=orchestrator -o wide
    echo ""
    echo "=== Metrics (sampled from each pod) ==="
    for pod in $(kubectl get pods -n {{ ns }} -l app=orchestrator -o name); do
        pod_name=$(basename $pod)
        echo "--- $pod_name ---"
        kubectl exec -n {{ ns }} $pod -- sh -c 'curl -sf http://127.0.0.1:9091/metrics 2>/dev/null | grep -E "^routers_(events|store|nats|total).*[^{]$" | sort' 2>/dev/null || echo "(exec failed)"
    done

# ── Run (local, for development) ─────────────────────────────────────────────

# Run the orchestrator locally with Valkey store (requires port-forwards).
orchestrator:
    NATS_URL={{ nats_url }} \
    VALKEY_URL={{ valkey_url }} \
    METRICS_ADDR=0.0.0.0:9091 \
        cargo run --release -p routers_realtime --bin orchestrator

# Run the orchestrator locally with in-memory store — no Valkey RTT, for benchmarking.
orchestrator-mem:
    NATS_URL={{ nats_url }} \
    STORE=memory \
    METRICS_ADDR=0.0.0.0:9091 \
        cargo run --release -p routers_realtime --bin orchestrator

# Run the realtime monitor viewer (live GPS + matched traces + shard boundaries).
# Starts a NATS port-forward automatically and tears it down on exit.
monitor:
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl port-forward -n {{ ns }} svc/nats 4222:4222 > /dev/null 2>&1 &
    PF_PID=$!
    trap "kill $PF_PID 2>/dev/null || true" EXIT INT TERM
    for i in $(seq 1 20); do
        nc -z 127.0.0.1 4222 2>/dev/null && break || sleep 0.3
    done
    echo "NATS forwarded — starting monitor"
    SHARD_DIR=../../target/shard_cache \
    NATS_URL="nats://127.0.0.1:4222" \
        cargo run -p routers_viewer --bin monitor --release

# Replay a large CSV via NATS JetStream (speed=1 is real-time; try 60 or 100).
# Set csv= to override the default sydney-dump-2026-thesis.csv.
# Set shards= to only send events in those geohashes (comma-separated).
# Set pipeline= to pipeline N JetStream acks in flood mode (default 1 = sequential).
# Example: just replay shards="r3grm,r3grh,r3grq,r3grw,r3grk,r3grj,r3grs,r3grt"
replay speed="60" csv="" shards="" pipeline="1" loops="1":
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl port-forward -n {{ ns }} pod/nats-0 4222:4222 > /dev/null 2>&1 &
    PF_PID=$!
    trap "kill $PF_PID 2>/dev/null || true" EXIT INT TERM
    for i in $(seq 1 20); do nc -z 127.0.0.1 4222 2>/dev/null && break || sleep 0.3; done
    export NATS_URL={{ nats_url }}
    export REPLAY_SPEED={{ speed }}
    export REPLAY_PIPELINE={{ pipeline }}
    export REPLAY_LOOPS={{ loops }}
    [[ -n "{{ csv }}" ]] && export CSV_FILE="{{ csv }}" || true
    [[ -n "{{ shards }}" ]] && export ACTIVE_SHARDS="{{ shards }}" || true
    export DEPLOY_SHARDS=1
    export SHARD_CACHE="$(realpath "{{ justfile_directory() }}/../../target/shard_cache")"
    cargo run --release -p routers_realtime --example replay_large

# Flood benchmark — measures end-to-end throughput through the full pipeline.
# stub=true  skips HMM (instant echo) to measure pure pipeline overhead ceiling.
# stub=false runs real HMM matching to verify no regression.
#
# Override defaults: just bench_pipeline=512 bench_loops=1 bench
# just bench_pipeline=512 bench_loops=1 bench stub=true
bench stub="false":
    #!/usr/bin/env bash
    set -euo pipefail
    ns={{ ns }}
    shards="{{ bench_shards }}"
    pipeline="{{ bench_pipeline }}"
    loops="{{ bench_loops }}"
    stub="{{ stub }}"
    shard_cache="$(realpath "{{ justfile_directory() }}/../../target/shard_cache")"
    mode_label=$( [[ "${stub}" == "true" ]] && echo "stub" || echo "real" )

    echo "=== Bench (mode=${mode_label}, pipeline=${pipeline}, loops=${loops}) ==="
    echo ""

    pkill -f "kubectl port-forward.*(prometheus|nats-0)" 2>/dev/null || true
    sleep 0.5
    kubectl port-forward -n ${ns} svc/prometheus-operated 19090:9090 > /dev/null 2>&1 &
    prom_pf=$!
    kubectl port-forward -n ${ns} pod/nats-0 19222:8222 > /dev/null 2>&1 &
    nats_mon_pf=$!
    kubectl port-forward -n ${ns} pod/nats-0 4222:4222 > /dev/null 2>&1 &
    nats_client_pf=$!
    trap 'kill "$prom_pf" "$nats_mon_pf" "$nats_client_pf" 2>/dev/null || true' EXIT

    for i in $(seq 1 20); do nc -z 127.0.0.1 4222 2>/dev/null && break || sleep 0.3; done

    prom_query() {
        curl -sf --max-time 3 "http://127.0.0.1:19090/api/v1/query?query=${1}" 2>/dev/null \
        | python3 -c "import sys,json; d=json.load(sys.stdin); r=d.get('data',{}).get('result',[]); print(r[0]['value'][1] if r else 0)" \
        2>/dev/null || echo "0"
    }
    get_nats_pending() {
        curl -sf --max-time 3 "http://127.0.0.1:19222/jsz?streams=1&consumers=1&accounts=1" 2>/dev/null \
        | python3 -c "import sys,json; d=json.load(sys.stdin); accts=d.get('account_details',[]); consumers=[c for a in accts for s in a.get('stream_detail',[]) for c in s.get('consumer_detail',[])]; print(-1 if not accts else sum(c.get('num_pending',0)+c.get('num_ack_pending',0) for c in consumers))" \
        2>/dev/null || echo "-1"
    }

    snap_matched=$(prom_query "sum%28routers_matches_total_success%29" || echo "0")

    echo "Flooding (pipeline=${pipeline})..."
    t_start=$(python3 -c "import time; print(int(time.time()*1000))")
    export NATS_URL="{{ nats_url }}"
    export REPLAY_FLOOD=1
    export REPLAY_PIPELINE="${pipeline}"
    export REPLAY_LOOPS="${loops}"
    export ACTIVE_SHARDS="${shards}"
    export DEPLOY_SHARDS=1
    export SHARD_CACHE="${shard_cache}"
    export K8S_NS="${ns}"
    [[ "${stub}" == "true" ]] && export MATCH_STUB=1 || unset MATCH_STUB
    cargo run -q --release -p routers_realtime --example replay_large
    t_flood_end=$(python3 -c "import time; print(int(time.time()*1000))")
    echo ""

    echo "Waiting for NATS drain..."
    deadline=$(( t_flood_end + 120000 ))
    while true; do
        pending=$(get_nats_pending)
        now=$(python3 -c "import time; print(int(time.time()*1000))")
        if [[ "$pending" == "0" ]] || (( now >= deadline )); then break; fi
        elapsed=$(echo "$now $t_start" | awk '{printf "%.1f", ($1-$2)/1000}')
        printf "\r  [%5.1fs]  NATS pending: %s   " "$elapsed" "$pending"
        sleep 1
    done
    t_end=$(python3 -c "import time; print(int(time.time()*1000))")
    echo ""

    # Prometheus scrapes every 1s — wait a few cycles so the final metrics are fresh.
    echo "Waiting for Prometheus scrape..."
    sleep 4

    end_matched=$(prom_query "sum%28routers_matches_total_success%29" || echo "0")
    total=$(echo "$end_matched $snap_matched" | awk '{printf "%d", $1-$2}')
    elapsed_s=$(echo "$t_end $t_start" | awk '{printf "%.2f", ($1-$2)/1000}')
    throughput=$(echo "$total $elapsed_s" | awk '{printf "%.0f", $1/$2}')

    echo ""
    echo "=== Results ==="
    echo "  Matched (${mode_label}):  ${total}"
    echo "  Wall time:        ${elapsed_s}s"
    echo "  Throughput:       ${throughput} evt/s"

# Shorthand for: just bench stub=true
bench-stub:
    just bench stub=true

# Build both binaries in release mode
build:
    cargo build -p routers_realtime --bins --release

# Run all tests for this crate
test:
    cargo test -p routers_realtime

# ── Observability ─────────────────────────────────────────────────────────────

# Print match outcome counts and latency summary across all running matcher pods
match-stats:
    #!/usr/bin/env bash
    ns={{ ns }}
    pods=$(kubectl get pods -n "$ns" -l app=matcher --no-headers 2>/dev/null | grep -v Terminating | awk '{print $1}')
    if [[ -z "$pods" ]]; then
        echo "No matcher pods found in namespace ${ns}."
        exit 0
    fi
    success=0; no_cand=0; errors=0
    solve_sum=0; solve_count=0
    match_sum=0; match_count=0
    for pod in $pods; do
        raw=$(kubectl exec -n "$ns" "$pod" -- sh -c 'curl -sf http://127.0.0.1:9092/metrics 2>/dev/null' 2>/dev/null || true)
        [[ -z "$raw" ]] && continue
        s=$(echo "$raw" | grep "^routers_matches_total_success " | awk '{print $2}'); success=$((success + ${s:-0}))
        n=$(echo "$raw" | grep "^routers_matches_total_no_candidate " | awk '{print $2}'); no_cand=$((no_cand + ${n:-0}))
        e=$(echo "$raw" | grep "^routers_matches_total_error " | awk '{print $2}'); errors=$((errors + ${e:-0}))
        ss=$(echo "$raw" | grep "^routers_solve_latency_ms_sum " | awk '{print $2}'); solve_sum=$(echo "$solve_sum $ss" | awk '{printf "%.3f",$1+$2}')
        sc=$(echo "$raw" | grep "^routers_solve_latency_ms_count " | awk '{print $2}'); solve_count=$((solve_count + ${sc:-0}))
        ms=$(echo "$raw" | grep "^routers_match_latency_ms_sum " | awk '{print $2}'); match_sum=$(echo "$match_sum $ms" | awk '{printf "%.3f",$1+$2}')
        mc=$(echo "$raw" | grep "^routers_match_latency_ms_count " | awk '{print $2}'); match_count=$((match_count + ${mc:-0}))
    done
    total=$((success + no_cand + errors))
    echo "=== Match outcomes ==="
    printf "  success      : %d\n" "$success"
    printf "  no_candidate : %d\n" "$no_cand"
    printf "  error        : %d\n" "$errors"
    printf "  total        : %d\n" "$total"
    echo ""
    if [[ "$solve_count" -gt 0 ]]; then
        avg_solve=$(echo "$solve_sum $solve_count" | awk '{printf "%.2f", $1/$2}')
        printf "  avg HMM solve time  : %s ms\n" "$avg_solve"
    fi
    if [[ "$match_count" -gt 0 ]]; then
        avg_match=$(echo "$match_sum $match_count" | awk '{printf "%.2f", $1/$2}')
        printf "  avg end-to-end time : %s ms\n" "$avg_match"
    fi

# Print live orchestrator metrics (aggregated across all pods, or localhost fallback)
metrics:
    #!/usr/bin/env bash
    ns={{ ns }}
    pods=$(kubectl get pods -n "$ns" -l app=orchestrator -o jsonpath='{.items[*].metadata.name}' 2>/dev/null)
    if [[ -n "$pods" ]]; then
        for pod in $pods; do
            echo "=== $pod ==="
            kubectl exec -n "$ns" "$pod" -- sh -c \
                'curl -sf http://127.0.0.1:9091/metrics 2>/dev/null | grep -v "^#" | sort' 2>/dev/null || true
        done
    else
        curl -sf http://127.0.0.1:9091/metrics | grep -v '^#' | sort
    fi

# Purge all messages from EVENTS and MATCH JetStream streams (clears backlog)
nats-purge:
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl port-forward -n {{ ns }} pod/nats-0 4222:4222 > /dev/null 2>&1 &
    PF_PID=$!
    trap "kill $PF_PID 2>/dev/null || true" EXIT INT TERM
    for i in $(seq 1 20); do nc -z 127.0.0.1 4222 2>/dev/null && break || sleep 0.3; done
    NATS_URL="{{ nats_url }}" cargo run -q -p routers_realtime --example nats_purge

# Delete the EVENTS stream entirely so it is recreated with correct subjects on next orchestrator start
nats-reset-events:
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl port-forward -n {{ ns }} pod/nats-0 4222:4222 > /dev/null 2>&1 &
    PF_PID=$!
    trap "kill $PF_PID 2>/dev/null || true" EXIT INT TERM
    for i in $(seq 1 20); do nc -z 127.0.0.1 4222 2>/dev/null && break || sleep 0.3; done
    NATS_URL="{{ nats_url }}" cargo run -q -p routers_realtime --example nats_purge -- --delete

# Print NATS JetStream stream stats
nats-stats:
    #!/usr/bin/env bash
    curl -sf http://127.0.0.1:8222/jsz | python3 -c "
    import sys, json
    d = json.load(sys.stdin)
    print(f'streams={d[\"streams\"]}  messages={d[\"messages\"]:,}  bytes={d[\"bytes\"]:,}')
    "

# Open the Grafana dashboard in the browser
dashboard:
    open http://127.0.0.1:3000/d/routers-realtime/routers-realtime
